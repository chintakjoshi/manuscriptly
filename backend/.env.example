APP_NAME=kaka-the-writer-backend
FLASK_ENV=development
FLASK_DEBUG=1
CORS_ORIGINS=http://localhost:5173
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/kaka_writer
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_MAX_TOKENS=1024
ANTHROPIC_TEMPERATURE=0.4
ANTHROPIC_MAX_TOOL_ITERATIONS=5
AGENT_MEMORY_SESSION_MESSAGE_LIMIT=6
AGENT_MEMORY_CROSS_SESSION_MESSAGE_LIMIT=8
AGENT_MEMORY_PLAN_LIMIT=5
SEED_DEFAULT_SUPERUSER=1
DEFAULT_SUPERUSER_USER_NAME=admin
DEFAULT_SUPERUSER_EMAIL=admin@example.com
DEFAULT_SUPERUSER_PASSWORD=admin123
